<!-- 游戏页面 - 阶段6版本 -->
<view class="container" style="background: linear-gradient(180deg, {{theme.colors.background}} 0%, {{theme.colors.background}} 100%);">
  <view class="content">
    <!-- 顶部信息栏 - 3个元素，各占1/3 -->
    <view class="info-bar" style="background: linear-gradient(135deg, {{theme.colors.primary}}, {{theme.colors.primaryDark}});">
      <!-- 难度显示（只读，横向布局） -->
      <view class="info-item difficulty-item">
        <text class="info-label">难度：</text>
        <text class="info-value">{{difficulties[difficultyIndex].label}}</text>
      </view>
      
      <!-- 错误计数 -->
      <view class="info-item error-item">
        <text class="info-label">错误：</text>
        <text class="error-count">{{errorCount}}/3</text>
      </view>
      
      <!-- 计时器 -->
      <view class="info-item timer-item">
        <text class="info-label">用时：</text>
        <text class="timer-text">{{currentTime}}</text>
      </view>
    </view>
    
    <!-- 最佳时间 -->
    <view class="best-time" wx:if="{{bestTime}}" style="background: {{theme.colors.sameNumber}};">
      <text class="best-time-label" style="color: {{theme.colors.textMedium}};">🏆 最佳:</text>
      <text class="best-time-value" style="color: {{theme.colors.textDark}};">{{bestTime}}</text>
    </view>
    
    <!-- 数独棋盘 -->
    <view class="board {{isPaused ? 'paused' : ''}}" style="background-color: {{theme.colors.boardFrame}};">
      <block wx:for="{{cells}}" wx:key="index">
        <view 
          class="cell {{item.isFixed ? 'fixed' : ''}} {{item.index === selectedIndex ? 'selected' : ''}} {{item.isRelated ? 'related' : ''}} {{item.isSameNumber ? 'same-number' : ''}} {{item.hasError ? 'error' : ''}} {{item.showHint ? 'hint-active' : ''}} {{item.isRightBorder ? 'border-right' : ''}} {{item.isBottomBorder ? 'border-bottom' : ''}}"
          style="{{item.index === selectedIndex ? 'background-color: ' + theme.colors.selected + ' !important;' : item.isRelated ? 'background-color: ' + theme.colors.related + ';' : item.isSameNumber ? 'background-color: ' + theme.colors.sameDigitHighlight + '; box-shadow: inset 0 0 0 2rpx ' + theme.colors.sameDigitRing + ';' : item.isFixed ? 'background-color: ' + theme.colors.fixed + ';' : 'background-color: ' + theme.colors.boardBg + ';'}}{{item.hasError ? ' background-color: ' + theme.colors.errorBg + ' !important;' : ''}}{{item.showHint ? ' background: linear-gradient(135deg, ' + theme.colors.hint + ', ' + theme.colors.success + ') !important;' : ''}}"
          data-index="{{item.index}}"
          bindtap="onCellTap">
          <!-- 正常数字 (暂停时隐藏) -->
          <text class="cell-text" wx:if="{{item.value && !item.showHint && !isPaused}}" style="color: {{item.index === selectedIndex ? theme.colors.selectedText : item.isRelated ? theme.colors.relatedText : item.isSameNumber ? theme.colors.sameDigitHighlightText : item.isFixed ? theme.colors.textDark : theme.colors.textDark}};">{{item.value}}</text>
          
          <!-- 提示数字（带动画，暂停时隐藏） -->
          <text class="hint-text" wx:if="{{item.showHint && !isPaused}}">{{item.hintValue}}</text>
          
          <!-- 笔记模式：候选数字（3×3网格，固定位置） -->
          <view class="notes-grid" wx:if="{{!item.value && !item.showHint && !isPaused && item.noteFlags}}">
            <text class="note-cell {{item.noteFlags.n1 ? 'show' : 'hide'}}" style="color: {{theme.colors.note}};">1</text>
            <text class="note-cell {{item.noteFlags.n2 ? 'show' : 'hide'}}" style="color: {{theme.colors.note}};">2</text>
            <text class="note-cell {{item.noteFlags.n3 ? 'show' : 'hide'}}" style="color: {{theme.colors.note}};">3</text>
            <text class="note-cell {{item.noteFlags.n4 ? 'show' : 'hide'}}" style="color: {{theme.colors.note}};">4</text>
            <text class="note-cell {{item.noteFlags.n5 ? 'show' : 'hide'}}" style="color: {{theme.colors.note}};">5</text>
            <text class="note-cell {{item.noteFlags.n6 ? 'show' : 'hide'}}" style="color: {{theme.colors.note}};">6</text>
            <text class="note-cell {{item.noteFlags.n7 ? 'show' : 'hide'}}" style="color: {{theme.colors.note}};">7</text>
            <text class="note-cell {{item.noteFlags.n8 ? 'show' : 'hide'}}" style="color: {{theme.colors.note}};">8</text>
            <text class="note-cell {{item.noteFlags.n9 ? 'show' : 'hide'}}" style="color: {{theme.colors.note}};">9</text>
          </view>
        </view>
      </block>
      
      <!-- 暂停遮罩 -->
      <view class="pause-overlay" wx:if="{{isPaused}}">
        <view class="pause-content">
          <text class="pause-icon">⏸</text>
          <text class="pause-text">游戏已暂停</text>
          <text class="pause-hint">点击"继续"按钮恢复游戏</text>
          
          <!-- 暂停时的操作按钮 -->
          <view class="pause-actions">
            <button class="pause-action-btn" style="background: linear-gradient(135deg, {{theme.colors.primary}}, {{theme.colors.primaryDark}}); box-shadow: 0 4rpx 12rpx {{theme.colors.shadow}};" bindtap="onNewGame">
              <text class="pause-action-icon">🔄</text>
              <text class="pause-action-label">新游戏</text>
            </button>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 底部工具栏 - 跟随棋盘（按键区白底 / 宠物区页面主题底，便于区分） -->
    <view class="bottom-toolbar {{numberPadLayout === 'double' ? 'number-pad-double' : ''}}">
    <view class="bottom-toolbar-keys" style="background: {{theme.colors.cardBg}}; border-top: 2rpx solid {{theme.colors.border}}; border-bottom: 2rpx solid {{theme.colors.border}}; box-shadow: 0 2rpx 12rpx {{theme.colors.shadow}};">
    <!-- 功能按钮行 -->
    <view class="toolbar-actions">
      <button class="tool-btn" bindtap="onUndo" disabled="{{!canUndo}}">
        <text class="tool-icon" style="color: {{theme.colors.textDark}};">↶</text>
        <text class="tool-label" style="color: {{theme.colors.textDark}};">撤销</text>
      </button>
      
      <button class="tool-btn" bindtap="onClearTap">
        <text class="tool-icon" style="color: {{theme.colors.textDark}};">🧹</text>
        <text class="tool-label" style="color: {{theme.colors.textDark}};">清除</text>
      </button>
      
      <button class="tool-btn {{isNoteMode ? 'active' : ''}}" style="{{isNoteMode ? 'background: ' + theme.colors.primaryLight + '; color: ' + theme.colors.textWhite + ';' : ''}}" bindtap="onToggleNoteMode">
        <text class="tool-icon" style="{{isNoteMode ? 'color: ' + theme.colors.textWhite + ';' : 'color: ' + theme.colors.textDark + ';'}}">✎</text>
        <text class="tool-label" style="{{isNoteMode ? 'color: ' + theme.colors.textWhite + ';' : 'color: ' + theme.colors.textDark + ';'}}">{{isNoteMode ? '填数' : '笔记'}}</text>
      </button>
      
      <button class="tool-btn" bindtap="onHint">
        <text class="tool-icon" style="color: {{theme.colors.textDark}};">💡</text>
        <text class="tool-label" style="color: {{theme.colors.textDark}};">提示</text>
      </button>
      
      <button class="tool-btn {{isPaused ? 'active' : ''}}" style="{{isPaused ? 'background: ' + theme.colors.primaryLight + '; color: ' + theme.colors.textWhite + ';' : ''}}" bindtap="onPause">
        <text class="tool-icon" style="{{isPaused ? 'color: ' + theme.colors.textWhite + ';' : 'color: ' + theme.colors.textDark + ';'}}">{{isPaused ? '▶' : '⏸'}}</text>
        <text class="tool-label" style="{{isPaused ? 'color: ' + theme.colors.textWhite + ';' : 'color: ' + theme.colors.textDark + ';'}}">{{isPaused ? '继续' : '暂停'}}</text>
      </button>
    </view>
    
    <!-- 数字菜单：支持单行/双行排列 -->
    <view class="number-grid {{numberPadLayout === 'double' ? 'two-rows' : 'one-row'}}">
      <block wx:for="{{numberPadRows}}" wx:key="index">
        <view class="number-row">
          <block wx:for="{{item}}" wx:key="*this">
            <view class="number-btn {{isNoteMode ? 'note-mode' : ''}}" style="border-color: {{theme.colors.border}}; {{isNoteMode ? 'background: ' + theme.colors.primaryLight + ';' : ''}}" data-num="{{item}}" bindtap="onNumberTap">
              <text class="number-main" style="color: {{isNoteMode ? theme.colors.textWhite : theme.colors.textDark}};">{{item}}</text>
              <text class="number-count" style="color: {{isNoteMode ? 'rgba(255, 255, 255, 0.8)' : theme.colors.textLight}};">{{numberCounts[item - 1]}}</text>
            </view>
          </block>
        </view>
      </block>
    </view>
    </view>

    <!-- 宠物：单宠可换位置；双宠左右固定 + 点一只另一只 peerTap -->
    <view wx:if="{{showGamePet && theme}}" class="pet-dock-strip" style="background: {{theme.colors.background}}; border-top: 2rpx solid {{theme.colors.border}};">
    <view class="pet-dock">
      <block wx:if="{{activePetIds.length === 1}}">
        <view class="pet-dock-inner pet-dock-inner--{{petDockLayout}}">
          <view class="pet-dock-stage">
            <view
              class="pet-img-wrap {{petGameShake ? 'pet-img-wrap--shake' : ''}}"
              bindtap="onPetGameTap"
            >
              <image
                wx:if="{{!gamePetImageFailed}}"
                class="pet-img"
                src="{{gamePetImageSrc}}"
                mode="aspectFit"
                binderror="onPetGameImageError"
              />
              <text wx:else class="pet-img-fallback">🐱</text>
            </view>
            <view class="pet-bubble-wrap" wx:if="{{petBubbleText}}">
              <view class="pet-bubble pet-bubble--gamefx {{petBubbleFadeIn ? 'is-visible' : ''}}" style="border-color: {{theme.colors.border}}; background: {{theme.colors.cardBg}};">
                <text class="pet-bubble-text" style="color: {{theme.colors.textDark}};">{{petBubbleText}}</text>
              </view>
            </view>
          </view>
        </view>
      </block>
      <view wx:elif="{{activePetIds.length === 2}}" class="pet-dock-dual-row">
        <view class="pet-dock-half">
          <view class="pet-dock-inner pet-dock-inner--left">
            <view class="pet-dock-stage">
              <view class="pet-img-wrap {{petDual0Shake ? 'pet-img-wrap--shake' : ''}}" bindtap="onPetDualTap" data-slot="0">
                <image wx:if="{{!petDual0Failed}}" class="pet-img" src="{{petDual0Image}}" mode="aspectFit" binderror="onPetDual0ImageError" />
                <text wx:else class="pet-img-fallback">🐱</text>
              </view>
              <view class="pet-bubble-wrap" wx:if="{{petBubbleText}}">
                <view class="pet-bubble pet-bubble--gamefx {{petBubbleFadeIn ? 'is-visible' : ''}}" style="border-color: {{theme.colors.border}}; background: {{theme.colors.cardBg}};">
                  <text class="pet-bubble-text" style="color: {{theme.colors.textDark}};">{{petBubbleText}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
        <view class="pet-dock-half">
          <view class="pet-dock-inner pet-dock-inner--right">
            <view class="pet-dock-stage">
              <view class="pet-img-wrap {{petDual1Shake ? 'pet-img-wrap--shake' : ''}}" bindtap="onPetDualTap" data-slot="1">
                <image wx:if="{{!petDual1Failed}}" class="pet-img" src="{{petDual1Image}}" mode="aspectFit" binderror="onPetDual1ImageError" />
                <text wx:else class="pet-img-fallback">🐱</text>
              </view>
              <view class="pet-bubble-wrap" wx:if="{{petBubble1Text}}">
                <view class="pet-bubble pet-bubble--gamefx {{petBubble1FadeIn ? 'is-visible' : ''}}" style="border-color: {{theme.colors.border}}; background: {{theme.colors.cardBg}};">
                  <text class="pet-bubble-text" style="color: {{theme.colors.textDark}};">{{petBubble1Text}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
    </view>
    </view>
  </view>

  <!-- 通关庆贺（有宠物时：图 + 文） -->
  <view
    class="win-pet-mask"
    wx:if="{{showWinPetOverlay && theme}}"
    catchtouchmove="onWinPetMaskMove"
  >
    <view class="win-pet-card" style="background: {{theme.colors.cardBg}}; box-shadow: 0 12rpx 40rpx {{theme.colors.shadowStrong}};">
      <view class="win-pet-hero-row">
        <view class="win-pet-hero">
          <image wx:if="{{winPetImageSrc && !winPetImageFailed}}" class="win-pet-img win-pet-img--dual" src="{{winPetImageSrc}}" mode="aspectFit" binderror="onWinPetImageError" />
          <text wx:else class="win-pet-fallback win-pet-fallback--dual">🐱</text>
        </view>
        <view class="win-pet-hero" wx:if="{{winPetImageSrc1}}">
          <image wx:if="{{winPetImageSrc1 && !winPetImageFailed1}}" class="win-pet-img win-pet-img--dual" src="{{winPetImageSrc1}}" mode="aspectFit" binderror="onWinPetImage1Error" />
          <text wx:else class="win-pet-fallback win-pet-fallback--dual">🐱</text>
        </view>
      </view>
      <text class="win-pet-name" style="color: {{theme.colors.primary}};">{{winPetPetName}}</text>
      <text class="win-pet-body" style="color: {{theme.colors.textDark}};">{{winPetBody}}</text>
      <view class="win-pet-actions">
        <view class="win-pet-btn win-pet-btn--primary" style="background: linear-gradient(135deg, {{theme.colors.primary}}, {{theme.colors.primaryDark}});" bindtap="onWinPetOverlayConfirm">
          <text style="color: {{theme.colors.textWhite}};">再来一局</text>
        </view>
        <view class="win-pet-btn win-pet-btn--ghost" style="border-color: {{theme.colors.border}};" bindtap="onWinPetOverlayCancel">
          <text style="color: {{theme.colors.textMedium}};">查看统计</text>
        </view>
      </view>
    </view>
  </view>
</view>
