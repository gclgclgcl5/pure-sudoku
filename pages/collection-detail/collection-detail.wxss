.detail-page {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: stretch;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 与收集页 .collection-swiper 完全一致：真机原生 swiper 对 flex:1/min-height 常失效，必须写死 height */
.detail-swiper {
  width: 100%;
  flex-shrink: 0;
  height: 680rpx;
  box-sizing: border-box;
}

.detail-footer {
  flex-shrink: 0;
  padding: 8rpx 40rpx 48rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.set-home-btn {
  border-radius: 999rpx;
  padding: 22rpx 36rpx;
  text-align: center;
}

.set-home-btn:active {
  opacity: 0.92;
  transform: scale(0.98);
}

.set-home-btn-text {
  font-size: 30rpx;
  font-weight: 600;
}

.detail-slide {
  height: 100%;
  min-height: 680rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  padding: 40rpx 48rpx;
}

.detail-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  max-width: 600rpx;
}

.detail-emoji-wrap {
  animation: detailFloat 3s ease-in-out infinite;
}

.detail-emoji {
  font-size: 200rpx;
  line-height: 1.1;
}

.detail-name {
  margin-top: 36rpx;
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.detail-desc {
  margin-top: 28rpx;
  font-size: 28rpx;
  line-height: 1.65;
  letter-spacing: 1rpx;
}

@keyframes detailFloat {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-16rpx);
  }
}
